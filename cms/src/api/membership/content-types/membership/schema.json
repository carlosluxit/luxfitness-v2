{
  "kind": "collectionType",
  "collectionName": "memberships",
  "info": {
    "singularName": "membership",
    "pluralName": "memberships",
    "displayName": "Membership",
    "description": "Membership plans and pricing"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "interval": {
      "type": "enumeration",
      "enum": ["month", "year"],
      "default": "month"
    },
    "description": {
      "type": "text"
    },
    "features": {
      "type": "json"
    },
    "highlighted": {
      "type": "boolean",
      "default": false
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}